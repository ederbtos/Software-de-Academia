{
  "defaults": {
    "standard": "WCAG2AA",
    "timeout": 30000,
    "wait": 800,
    "chromeLaunchConfig": {
      "args": ["--no-sandbox"]
    },
    "actions": [
      "wait for element input[name=\"email\"] to be visible",
      "set field input[name=\"email\"] to admin@sistema.com",
